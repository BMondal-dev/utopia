{
  "name": "clarus/backend",
  "type": "project",
  "autoload": {
    "psr-4": {
      "Clarus\\": "src/Clarus/"
    }
  },
  "authors": [
    {
      "name": "Bijit Mondal"
    }
  ],
  "require": {
    "utopia-php/http": "^2.0@RC",
    "utopia-php/platform": "^1.0@RC",
    "utopia-php/database": "^6.0",
    "utopia-php/config": "^1.0",
    "utopia-php/validators": "^0.2",
    "utopia-php/pools": "^1.0",
    "utopia-php/system": "^0.10",
    "ext-swoole": "*",
    "utopia-php/auth": "^0.7",
    "adhocore/jwt": "^1.1"
  },
  "require-dev": {
    "swoole/ide-helper": "6.*",
    "laravel/pint": "^1.29"
  },
  "scripts": {
    "post-install-cmd": [
      "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
    ],
    "post-update-cmd": [
      "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
    ],
    "format": "pint",
    "format:test": "pint --test"
  },
  "config": {
    "platform": {
      "ext-protobuf": "3.0.0",
      "ext-opentelemetry": "1.0.0",
      "ext-redis": "6.0.0",
      "ext-yaml": "2.0.0"
    },
    "allow-plugins": {
      "php-http/discovery": true,
      "tbachert/spi": true
    }
  }
}
