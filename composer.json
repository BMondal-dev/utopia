{
    "name": "clarus/backend",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Clarus\\": "src/Clarus/"
        }
    },
    "authors": [
        {
            "name": "Bijit Mondal"
        }
    ],
    "require": {
        "utopia-php/http": "^2.0@RC",
        "utopia-php/platform": "^1.0@RC",
        "utopia-php/database": "^6.0",
        "utopia-php/config": "^1.0",
        "utopia-php/registry": "^0.5",
        "utopia-php/validators": "^0.2",
        "utopia-php/console": "^0.1",
        "utopia-php/pools": "^1.0",
        "utopia-php/system": "^0.10",
        "ext-swoole": "*"
    },
    "require-dev": {
        "swoole/ide-helper": "6.*"
    },
    "config": {
        "platform": {
            "ext-protobuf": "3.0.0",
            "ext-opentelemetry": "1.0.0",
            "ext-redis": "6.0.0",
            "ext-yaml": "2.0.0"
        },
        "allow-plugins": {
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    }
}
